---
import Layout from "../../../layouts/Layout.astro";
import App from "../../../components/App.svelte";
import Cart from "../../../components/Checkout/Cart.svelte";
import Summary from "../../../components/Checkout/Summary.svelte";
import Steps from "../../../components/Checkout/Steps.svelte";
import BackButton from "../../../components/BackButton.svelte";
import { getPlatoniqAccountingId, getDefaultCurrency } from "../../../utils/consts";

const { t, lang, session } = Astro.locals;
const defaultCurrency = getDefaultCurrency();
const accountingIdPlatoniq = Number(getPlatoniqAccountingId() || 0);
---

<Layout title={t("metadata.title")} description={t("metadata.description")}>
    <App client:load locale={lang} session={session} />
    <div class="flex flex-col gap-8 pt-10 lg:mx-auto lg:max-w-360 lg:flex-row lg:px-8 lg:py-10">
        <div class="flex w-full flex-col gap-10 px-4 lg:w-1/2 lg:px-0">
            <BackButton client:load />

            <div class="flex flex-col gap-4">
                <h2 class="text-[40px]/[48px] font-bold tracking-[0%] text-black">
                    {t("checkout.title")}
                </h2>
                <p class="text-content">
                    {t("checkout.subtitle")}
                </p>
            </div>

            <Cart client:load {defaultCurrency} {accountingIdPlatoniq} />
        </div>
        <div
            class="sticky right-0 bottom-0 left-0 flex h-fit w-full flex-col gap-6 rounded-t-3xl border-t border-r border-l bg-white pt-6 pr-4 pb-6 pl-4 lg:sticky lg:top-10 lg:right-auto lg:bottom-auto lg:left-auto lg:h-fit lg:w-1/2 lg:gap-6 lg:rounded-[40px] lg:border lg:p-6"
        >
            <Summary client:load />
            <div class="lg:block" id="checkout-details">
                <Steps client:load step={1} />
                <div class="flex flex-col px-0 pt-6 pb-0 lg:px-6 lg:pt-0 lg:pb-0">
                    <p class="text-content text-sm">{t("checkout.summary.deduct")}</p>
                </div>
            </div>
            <div class="flex flex-col items-end px-0 pt-0 pb-0 lg:px-6 lg:pt-0 lg:pb-0">
                <a
                    class="bg-primary text-secondary w-fit cursor-pointer rounded-3xl px-6 py-4 font-bold"
                    href="/checkout/payment"
                >
                    {t("global.btn.continue")}
                </a>
            </div>
        </div>
    </div>
</Layout>
