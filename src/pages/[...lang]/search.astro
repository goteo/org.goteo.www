---
import Layout from "../../layouts/Layout.astro";
import App from "../../components/App.svelte";
import SearchFilters from "../../components/search/SearchFilters.svelte";
import SearchResultsClient from "../../components/search/SearchResultsClient.svelte";

import type { Project } from "../../openapi/client/types.gen";

const { t, lang, session } = Astro.locals;

// Initial projects will be fetched client-side to avoid blocking SSR
const initialProjects: Project[] = [];

// URL search parameters for SSR
const url = new URL(Astro.request.url);

const { searchParams } = url;

const initialFilters = {
    query: searchParams.get("q") || "",
    statusFilter: searchParams.get("status") || "",
    categories: searchParams.get("categories")?.split(",").filter(Boolean) || [],
    territory: {
        country: searchParams.get("country") || null,
        subLvl1: searchParams.get("subLvl1") || null,
        subLvl2: searchParams.get("subLvl2") || null,
        rawQuery: searchParams.get("locationText") || "",
    },
};

const hasInitialSearch = !!(
    initialFilters.query ||
    initialFilters.statusFilter ||
    initialFilters.categories.length > 0 ||
    initialFilters.territory.rawQuery
);
---

<Layout title={t("search.title")} description={t("search.description")}>
    <App client:load locale={lang} session={session} />
    <section class="wrapper">
        <div class="mb-12 text-center">
            <h1 class="text-secondary mb-4 text-4xl font-bold">
                {t("search.heading")}
            </h1>
            <p class="text-secondary text-lg">
                {t("search.subtitle")}
            </p>
        </div>

        <!-- Search Filters -->
        <div class="mb-8">
            <SearchFilters client:load locale={lang} initialFilters={initialFilters} />
        </div>

        <!-- Search Results -->
        <div class="mb-8" role="region" aria-label={t("search.results.regionLabel")}>
            <SearchResultsClient
                client:load
                initialProjects={initialProjects}
                initialFilters={initialFilters}
                hasInitialSearch={hasInitialSearch}
            />
        </div>
    </section>
</Layout>
