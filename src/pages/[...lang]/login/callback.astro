---
import CSRF from "csrf";
import LocalStorage from "../../../components/LocalStorage.svelte";
import Redirect from "../../../components/Redirect.svelte";
import { LOCAL_STORAGE_KEY } from "../../../auth/store";
import { type OAuthResponse } from "../../../auth/types";
import {
    apiUsersGetCollection,
    apiUsersIdorganizationGet,
    apiUsersIdpersonGet,
} from "../../../openapi/client";

const code = Astro.url.searchParams.get("code");
if (code === null) {
    console.error("Visited OAuth2 login callback without code");
    return Astro.redirect("/error");
}

const csrfToken = Astro.url.searchParams.get("state");
if (csrfToken === null) {
    console.error("Visited OAuth2 login callback without CSRF token");
    return Astro.redirect("/error");
}

const csrfCookie = Astro.cookies.get("oauth-csrf");
if (!csrfCookie || csrfToken !== csrfCookie.value) {
    console.error("The OAuth2 CSRF cookie was not present or mismatched");
    return Astro.redirect("/error");
} else {
    Astro.cookies.delete("oauth-csrf");
}

const csrf = new CSRF();
if (!csrf.verify(import.meta.env.OAUTH2_CLIENT_SECRET, csrfToken)) {
    console.error(`Could not verify CSRF token: ${csrfToken}`);
    return Astro.redirect("/error");
}

const oauth2Token = new URL("/oauth/token", import.meta.env.PUBLIC_API_URL);
const params = new URLSearchParams();

params.set("grant_type", "authorization_code");
params.set("code", code);
params.set("redirect_uri", new URL("/login/callback", Astro.url).toString());
params.set("client_id", import.meta.env.OAUTH2_CLIENT_ID);
params.set("client_secret", import.meta.env.OAUTH2_CLIENT_SECRET);

const oauth: OAuthResponse = await fetch(oauth2Token, {
    method: "POST",
    body: params,
    headers: { "Content-Type": "application/x-www-form-urlencoded" },
}).then((res) => res.json());

if (oauth.error!) {
    console.error(oauth);
    return Astro.redirect("/error");
}

const { sub: handle } = JSON.parse(
    Buffer.from(oauth.access_token.split(".")[1], "base64").toString(),
);

const user = await apiUsersGetCollection({ query: { handle } }).then(({ data }) => data![0]);
const { data: person } = await apiUsersIdpersonGet({
    path: { id: String(user.id) },
    headers: { Authorization: `${oauth.token_type} ${oauth.access_token}` },
});
const { data: organization } = await apiUsersIdorganizationGet({
    path: { id: String(user.id) },
    headers: { Authorization: `${oauth.token_type} ${oauth.access_token}` },
});

const auth = { token: oauth, user, person, organization };

Astro.cookies.set("auth", auth, { path: "/" });

const withCallback = Astro.cookies.get("callback");
Astro.cookies.delete("callback");
---

<LocalStorage set={{ [LOCAL_STORAGE_KEY]: auth }} client:load />
<Redirect location={withCallback?.value || "/"} client:load />
