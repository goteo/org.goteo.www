---
import CSRF from "csrf";
import { getSession, isExpired } from "../../../auth/session";

const wantsCallback = Astro.url.searchParams.get("callback");
if (wantsCallback) {
    Astro.cookies.delete("callback");
    Astro.cookies.set("callback", wantsCallback, { path: "/" });
}

const session = await getSession(Astro.cookies);
if (session && !isExpired(session)) {
    return Astro.redirect(wantsCallback || "/");
}

const oauth2Authorize = new URL("/oauth/authorize", import.meta.env.PUBLIC_API_URL);

oauth2Authorize.searchParams.set("client_id", import.meta.env.OAUTH2_CLIENT_ID);
oauth2Authorize.searchParams.set("redirect_uri", new URL("/login/callback", Astro.url).toString());
oauth2Authorize.searchParams.set("response_type", "code");
oauth2Authorize.searchParams.set("scope", "email");

const csrf = new CSRF();
const csrfToken = csrf.create(import.meta.env.OAUTH2_CLIENT_SECRET);

Astro.cookies.set("oauth-csrf", csrfToken);
oauth2Authorize.searchParams.set("state", csrfToken);

return Astro.redirect(oauth2Authorize);
---
