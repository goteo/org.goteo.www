---
import Layout from "../../../layouts/Layout.astro";
import Table from "./Table.svelte";
import Cell from "./Cell.svelte";
import PhasesCarousel from "./PhasesCarousel.svelte";

const { t } = Astro.locals;

const phases = [
    {
        title: t("pages.about.phases.items.preparation.title"),
        description: t("pages.about.phases.items.preparation.description"),
    },
    {
        title: t("pages.about.phases.items.launch.title"),
        description: t("pages.about.phases.items.launch.description"),
    },
    {
        title: t("pages.about.phases.items.fundsReceived.title"),
        description: t("pages.about.phases.items.fundsReceived.description"),
    },
    {
        title: t("pages.about.phases.items.followUp.title"),
        description: t("pages.about.phases.items.followUp.description"),
    },
];
---

<Layout title={t("metadata.title")} description={t("metadata.description")}>
    <!-- Hero section -->
    <section class="w-full py-32">
        <div class="wrapper text-center">
            <div class="mx-auto max-w-3xl space-y-8">
                <h1
                    class="text-secondary bg-linear-to-r bg-clip-text text-4xl leading-tight font-bold lg:text-6xl"
                >
                    {t("pages.about.hero.title")}
                </h1>
                <p class="text-secondary mx-auto max-w-2xl text-lg leading-relaxed">
                    {t("pages.about.hero.description")}
                </p>
                <div class="flex justify-center">
                    <a
                        href="/create/project"
                        class="bg-primary text-secondary inline-flex items-center justify-center rounded-3xl px-8 py-4 font-bold transition hover:opacity-90"
                    >
                        {t("pages.about.hero.cta")}
                    </a>
                </div>
            </div>
        </div>
    </section>

    <!-- What is crowdfunding -->
    <section class="wrapper py-20">
        <div class="grid items-center gap-12 lg:grid-cols-2">
            <div class="space-y-4">
                <h2 class="text-secondary text-3xl font-bold lg:text-4xl">
                    {t("pages.about.whatIs.title")}
                </h2>
                <p class="text-secondary text-xl font-bold">{t("pages.about.whatIs.subtitle")}</p>
                <p class="text-content leading-relaxed">{t("pages.about.whatIs.description")}</p>
            </div>
            <div class="bg-grey aspect-4/3 rounded-2xl"></div>
        </div>
    </section>

    <!-- Advisory and support -->
    <section class="wrapper py-20">
        <div class="grid items-center gap-12 lg:grid-cols-2">
            <div class="bg-grey aspect-4/3 rounded-2xl"></div>
            <div class="border-variant1 bg-purple-soft space-y-6 rounded-3xl border p-8 lg:p-12">
                <h2 class="text-secondary text-2xl font-bold lg:text-3xl">
                    {t("pages.about.advisory.title")}
                </h2>
                <p class="text-content leading-relaxed">{t("pages.about.advisory.description")}</p>
                <a
                    href="#"
                    class="text-secondary inset-ring-secondary inline-flex items-center justify-center rounded-3xl px-8 py-4 font-bold inset-ring-1 transition hover:opacity-90"
                >
                    {t("pages.about.advisory.cta")}
                </a>
            </div>
        </div>
    </section>

    <!-- Phases and mechanics -->
    <section class="wrapper py-20">
        <h2 class="text-secondary mb-10 text-2xl font-bold lg:text-3xl">
            {t("pages.about.phases.title")}
        </h2>
        <PhasesCarousel client:load {phases} />
    </section>

    <!-- Training and events -->
    <section class="bg-secondary w-full py-20">
        <div class="wrapper">
            <h2 class="mb-10 text-3xl font-bold text-white lg:text-4xl">
                {t("pages.about.events.title")}
            </h2>
            <div class="grid items-center gap-12 lg:grid-cols-2">
                <div class="aspect-4/3 rounded-2xl bg-white/10"></div>
                <div class="space-y-6">
                    <p class="leading-relaxed text-white/80">
                        {t("pages.about.events.description")}
                    </p>
                    <a
                        href="#"
                        class="bg-primary text-secondary inline-flex items-center justify-center rounded-3xl px-8 py-4 font-bold transition hover:opacity-90"
                    >
                        {t("pages.about.events.cta")}
                    </a>
                </div>
            </div>
        </div>
    </section>

    <!-- Goteo advantages -->
    <section class="wrapper py-20">
        <Table title={t("pages.about.advantages.title")} cols={2}>
            <Cell title={t("pages.about.advantages.items.taxDeductions.title")}>
                {t("pages.about.advantages.items.taxDeductions.description")}
            </Cell>
            <Cell title={t("pages.about.advantages.items.allOrNothing.title")}>
                {t("pages.about.advantages.items.allOrNothing.description")}
            </Cell>
            <Cell title={t("pages.about.advantages.items.twoRounds.title")}>
                {t("pages.about.advantages.items.twoRounds.description")}
            </Cell>
            <Cell title={t("pages.about.advantages.items.personalizedSupport.title")}>
                {t("pages.about.advantages.items.personalizedSupport.description")}
            </Cell>
            <Cell title={t("pages.about.advantages.items.loyalCommunity.title")}>
                {t("pages.about.advantages.items.loyalCommunity.description")}
            </Cell>
            <Cell title={t("pages.about.advantages.items.matchfunding.title")}>
                {t("pages.about.advantages.items.matchfunding.description")}
            </Cell>
            <Cell title={t("pages.about.advantages.items.socialImpact.title")}>
                {t("pages.about.advantages.items.socialImpact.description")}
            </Cell>
            <Cell title={t("pages.about.advantages.items.transparency.title")}>
                {t("pages.about.advantages.items.transparency.description")}
            </Cell>
            <Cell title={t("pages.about.advantages.items.provenMethodology.title")}>
                {t("pages.about.advantages.items.provenMethodology.description")}
            </Cell>
        </Table>
    </section>
</Layout>
