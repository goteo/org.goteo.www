---
import Layout from "../../../layouts/Layout.astro";
import App from "../../../components/App.svelte";
import Summary from "../../../components/Checkout/Summary.svelte";
import WalletConfirmation from "../../../components/Checkout/WalletConfirmation.astro";
import Steps from "../../../components/Checkout/Steps.svelte";
import Card from "../../../components/library/Card.svelte";
import BackButton from "../../../components/BackButton.astro";
import { apiAccountingsIdGet } from "../../../openapi/client/index";
import { getDefaultCurrency, getPlatoniqAccountingId } from "../../../utils/consts.ts";
import { extractId } from "../../../utils/extractId.ts";

const { t, lang, session } = Astro.locals;
const defaultCurrency = getDefaultCurrency();
const accountingIdPlatoniq = Number(getPlatoniqAccountingId() || 0);

if (!session) {
    return Astro.redirect("/login?callback=/checkout/wallet");
}
const { token, user } = session;

const { data: accounting } = await apiAccountingsIdGet({
    path: { id: extractId(user.accounting)! },
    headers: {
        Authorization: `${token.token_type} ${token.access_token}`,
    },
});
---

<Layout title={t("metadata.title")} description={t("metadata.description")}>
    <App client:load locale={lang} session={session}>
        <div class="wrapper">
            <div class="flex flex-col gap-8 py-10 lg:flex-row">
                <div class="flex w-full flex-col gap-10 lg:w-1/2">
                    <BackButton />

                    <div class="flex flex-col gap-4">
                        <div class="flex flex-col gap-10">
                            <div class="flex flex-col gap-4">
                                <h2 class="text-[40px]/[48px] font-bold tracking-[0%] text-black">
                                    {t("payment.wallet-confirmation.title")}
                                </h2>
                                <p class="text-content">
                                    {t("payment.wallet-confirmation.description")}
                                </p>
                            </div>

                            <WalletConfirmation {accounting} {defaultCurrency} />
                        </div>
                    </div>
                </div>
                <Card
                    class="lg: sticky -bottom-6 flex h-fit w-full flex-col items-start gap-6 rounded-3xl border-black pr-4 pb-10 pl-4 lg:top-(--sticky-top) lg:bottom-auto lg:w-1/2 lg:gap-6 lg:rounded-[40px] lg:p-6"
                >
                    <Summary
                        client:load
                        currency={defaultCurrency}
                        {accountingIdPlatoniq}
                        hasError={false}
                        amount={undefined}
                    />
                    <div class="w-full lg:block" id="checkout-details">
                        <div class="w-full">
                            <Steps step={3} hasError={false} client:load />
                        </div>
                        <div class="flex flex-col">
                            <p class="text-content text-sm">{t("checkout.summary.deduct")}</p>
                        </div>
                    </div>
                    <div class="flex flex-col items-end">
                        <a
                            href="/checkout/verify"
                            class="bg-primary text-secondary w-fit cursor-pointer rounded-3xl px-6 py-4 font-bold"
                        >
                            {t("global.btn.continue")}
                        </a>
                    </div>
                </Card>
            </div>
        </div>
    </App>
</Layout>
