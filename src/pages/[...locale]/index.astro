---
import App from "../../components/App.svelte";
import Layout from "../../layouts/Layout.astro";
import Hero from "../../components/Hero/Hero.astro";
import Campaigns from "../../components/home/Campaigns.astro";
import CampaignsTabs from "../../components/home/CampaignsTabs.astro";
import Stats from "../../components/home/Stats.astro";
import Stories from "../../components/home/Stories.astro";
import FeaturedPromoters from "../../components/home/FeaturedPromoters.astro";
import Resources from "../../components/home/Resources.astro";
import Blog from "../../components/home/Blog.astro";
import Matchfunding from "../../components/home/Matchfunding.astro";
import HomeBanner from "../../components/library/HomeBanner.svelte";
import { isSupportedLocale } from "../../i18n/locales";
import { NotFound } from "../../utils/responses";

const { locale } = Astro.params;

if (locale && !isSupportedLocale(locale)) {
    return NotFound;
}

const { t, lang, session } = Astro.locals;
---

<Layout title={t("metadata.title")} description={t("metadata.description")} class="mb-20 gap-18">
    <App client:load locale={lang} session={session} />
    <Hero />
    <HomeBanner
        title={t("homeBanner.title")}
        description={t("homeBanner.description")}
        ctaText={t("homeBanner.ctaText")}
        ctaLink={t("homeBanner.ctaLink")}
        closeAriaLabel={t("homeBanner.closeAriaLabel")}
    />
    <Campaigns />
    <Blog />
    <Stats />
    <CampaignsTabs />
    <Matchfunding />
    <!-- <Stories /> -->
    <FeaturedPromoters />
    <!-- <Resources /> -->
</Layout>
