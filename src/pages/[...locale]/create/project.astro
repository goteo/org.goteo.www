---
import { getSession } from "../../../auth/session";
import Layout from "../../../layouts/Layout.astro";
import App from "../../../components/App.svelte";
import CreateProjectForm from "./CreateProjectForm.svelte";

const { t, lang, session } = Astro.locals;

if (!getSession(Astro.cookies)) {
    return Astro.redirect("/login");
}
---

<Layout title={t("pages.project.create.title")}>
    <App client:load locale={lang} session={session}>
        <CreateProjectForm client:load />
    </App>
</Layout>
