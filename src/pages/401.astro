---
import EyeInLaptop from "../components/ErrorPage/EyeInLaptop.svelte";
import ErrorPage from "../components/ErrorPage/ErrorPage.svelte";
import Layout from "../layouts/Layout.astro";
import App from "../components/App.svelte";

const { t, lang, session } = Astro.locals;
---

<Layout title={t("pages.401.meta.title")} description={t("pages.401.meta.description")}>
    <App locale={lang} session={session} client:load />
    <ErrorPage
        code={401}
        title={t("pages.401.title")}
        subtitle={t("pages.401.subtitle")}
        ctaHref="/login"
        ctaText={t("common.login")}
    >
        <EyeInLaptop />
    </ErrorPage>
</Layout>
