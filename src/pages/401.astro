---
import EyeInLaptop from "../components/ErrorPage/EyeInLaptop.svelte";
import Error from "../components/ErrorPage/Error.svelte";
import Layout from "../layouts/Layout.astro";

const { t } = Astro.locals;
---

<Layout title={t("pages.401.meta.title")} description={t("pages.401.meta.description")}>
    <Error
        code={401}
        title={t("pages.401.title")}
        subtitle={t("pages.401.subtitle")}
        ctaHref="/login"
        ctaText={t("common.login")}
    >
        <EyeInLaptop />
    </Error>
</Layout>
