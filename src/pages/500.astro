---
import App from "../components/App.svelte";
import ErrorPage from "../components/ErrorPage/ErrorPage.svelte";
import EyeInLaptop from "../components/ErrorPage/EyeInLaptop.svelte";
import Layout from "../layouts/Layout.astro";

const { t, lang, session } = Astro.locals;
---

<Layout title={t("pages.500.meta.title")} description={t("pages.500.meta.description")}>
    <App locale={lang} session={session} client:load>
        <ErrorPage
            code={500}
            title={t("pages.500.title")}
            subtitle={t("pages.500.subtitle")}
            ctaText={t("common.goHome")}
        >
            <EyeInLaptop />
        </ErrorPage>
    </App>
</Layout>
